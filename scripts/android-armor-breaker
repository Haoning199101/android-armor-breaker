#!/bin/bash
# Android Armor Breaker - Main wrapper script
# Version 2.0.1 - Added VDEX processing capability for NetEase Yidun reinforcement

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR" || exit 1

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_header() {
    echo -e "${BLUE}"
    echo "================================================"
    echo "    Android Armor Breaker v2.2.0"
    echo "    Multi-strategy Android App Unpacking Tool"
    echo "================================================"
    echo "    Strategies: Frida • Root Memory • VDEX • Snapshot"
    echo "================================================"
    echo -e "${NC}"
}

print_usage() {
    echo "Usage:"
    echo "  $0 analyze --apk <apk_file> [--verbose]"
    echo "      Analyze APK protection type and level"
    echo ""
    echo "  $0 --package <package_name> [options]"
    echo "      Unpack Android application (Intelligent Strategy Selection)"
    echo ""
    echo "Options for unpacking:"
    echo "  --output <dir>         Output directory (default: auto-generated)"
    echo "  --attempts <num>       Number of unpacking attempts (default: 3)"
    echo "  --deep-search          Enable deep search mode"
    echo "  --bypass-antidebug     Enable anti-debug bypass"
    echo "  --verbose              Verbose output"
    echo "  --strategy <strategy>  Unpacking strategy: auto, frida, root, snapshot"
    echo "                         auto: Automatically selects best strategy based on protection type (recommended)"
    echo "                         frida: Frida dynamic unpacking (default, for no or basic reinforcement)"
    echo "                         root:  Root memory extraction (bypasses commercial reinforcements like IJIAMI, Bangcle, 360, etc.)"
    echo "                         snapshot: Memory snapshot attack (for immediately crashing apps)"
    echo "  --apk <apk_file>       APK file path (for automatic strategy analysis)"
    echo ""
    echo "Examples:"
    echo "  $0 analyze --apk /path/to/app.apk --verbose"
    echo "  $0 --package com.example.app --deep-search --verbose"
    echo "  $0 --package com.example.app --bypass-antidebug --output ./dex_files"
    echo "  $0 --package com.target.app --strategy root --verbose (bypass commercial reinforcement)"
    echo "  $0 --package com.target.app --strategy auto --apk /path/to/app.apk (intelligent unpacking)"
}

check_dependencies() {
    local missing=0
    
    echo -e "${YELLOW}[*] Checking dependencies...${NC}"
    
    # Required dependencies
    if ! command -v python3 &> /dev/null; then
        echo -e "${RED}[!] Python3 not found${NC}"
        missing=1
    fi
    
    if ! command -v adb &> /dev/null; then
        echo -e "${RED}[!] ADB not found (required for device connection)${NC}"
        missing=1
    fi
    
    # Optional dependencies (Frida, only needed for Frida strategy)
    if ! command -v frida &> /dev/null; then
        echo -e "${YELLOW}[!] Frida not found (optional, needed for Frida strategy)${NC}"
        echo -e "${YELLOW}[!] Install with: pip install frida-tools${NC}"
    fi
    
    if ! command -v frida-dexdump &> /dev/null; then
        echo -e "${YELLOW}[!] frida-dexdump not found (optional, needed for Frida strategy)${NC}"
        echo -e "${YELLOW}[!] Install with: pip install frida-tools${NC}"
    fi
    
    if [ $missing -eq 0 ]; then
        echo -e "${GREEN}[+] Required dependencies found${NC}"
        echo -e "${YELLOW}[!] Note: Frida tools are optional (only needed for Frida strategy)${NC}"
        return 0
    else
        echo -e "${RED}[!] Required dependencies are missing${NC}"
        return 1
    fi
}

analyze_apk() {
    local apk_file=""
    local verbose=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --apk)
                apk_file="$2"
                shift 2
                ;;
            --verbose)
                verbose="--verbose"
                shift
                ;;
            *)
                echo -e "${RED}[!] Unknown argument: $1${NC}"
                print_usage
                exit 1
                ;;
        esac
    done
    
    if [ -z "$apk_file" ]; then
        echo -e "${RED}[!] APK file not specified. Use --apk <file>${NC}"
        exit 1
    fi
    
    if [ ! -f "$apk_file" ]; then
        echo -e "${RED}[!] APK file not found: $apk_file${NC}"
        exit 1
    fi
    
    echo -e "${YELLOW}[*] Analyzing APK: $apk_file${NC}"
    python3 apk_protection_analyzer.py --apk "$apk_file" $verbose
}

unpack_app() {
    local package=""
    local output=""
    local attempts=""
    local deep_search=""
    local bypass_antidebug=""
    local verbose=""
    local strategy=""
    local apk_file=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --package)
                package="$2"
                shift 2
                ;;
            --output)
                output="$2"
                shift 2
                ;;
            --attempts)
                attempts="$2"
                shift 2
                ;;
            --deep-search)
                deep_search="true"
                shift
                ;;
            --bypass-antidebug)
                bypass_antidebug="true"
                shift
                ;;
            --verbose)
                verbose="true"
                shift
                ;;
            --strategy)
                strategy="$2"
                shift 2
                ;;
            --apk)
                apk_file="$2"
                shift 2
                ;;
            *)
                echo -e "${RED}[!] Unknown argument: $1${NC}"
                print_usage
                exit 1
                ;;
        esac
    done
    
    if [ -z "$package" ]; then
        echo -e "${RED}[!] Package name not specified. Use --package <name>${NC}"
        exit 1
    fi
    
    # 警告：attempts参数当前被忽略
    if [ -n "$attempts" ]; then
        echo -e "${YELLOW}[!] Warning: --attempts parameter is currently ignored${NC}"
        echo -e "${YELLOW}[!] It will be supported in a future version${NC}"
    fi
    
    # 构建命令
    cmd="python3 unpack_orchestrator.py --package \"$package\""
    
    if [ -n "$output" ]; then
        cmd="$cmd --output \"$output\""
    fi
    
    if [ -n "$strategy" ]; then
        cmd="$cmd --strategy \"$strategy\""
    else
        # Default strategy: auto if apk file provided, otherwise frida
        if [ -n "$apk_file" ]; then
            cmd="$cmd --strategy auto"
        else
            cmd="$cmd --strategy frida"
            echo -e "${YELLOW}[!] No strategy specified, using default Frida strategy${NC}"
            echo -e "${YELLOW}[!] Recommendation: Provide --apk parameter to enable intelligent strategy selection${NC}"
        fi
    fi
    
    if [ -n "$apk_file" ]; then
        cmd="$cmd --apk \"$apk_file\""
    fi
    
    if [ "$deep_search" = "true" ]; then
        cmd="$cmd --deep-search"
    fi
    
    if [ "$bypass_antidebug" = "true" ]; then
        cmd="$cmd --bypass-antidebug"
    fi
    
    if [ "$verbose" = "true" ]; then
        cmd="$cmd --verbose"
    fi
    
    echo -e "${YELLOW}[*] Unpacking application: $package${NC}"
    if [ -n "$strategy" ]; then
        echo -e "${YELLOW}[*] Strategy: $strategy${NC}"
    fi
    if [ -n "$apk_file" ]; then
        echo -e "${YELLOW}[*] APK for analysis: $(basename "$apk_file")${NC}"
    fi
    
    # 执行命令
    eval $cmd
}

# Main execution
print_header

if [ $# -eq 0 ]; then
    print_usage
    exit 0
fi

# Check dependencies
check_dependencies || exit 1

# Parse command
case "$1" in
    analyze)
        shift
        analyze_apk "$@"
        ;;
    --help|-h)
        print_usage
        ;;
    --version)
        echo "Android Armor Breaker v2.2.0"
        ;;
    *)
        # Assume unpack command
        unpack_app "$@"
        ;;
esac